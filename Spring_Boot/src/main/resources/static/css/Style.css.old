@charset "ISO-8859-1";

body {
	background-image: url("/img/silent.png");
	background-size: contain;
	background-repeat: repeat;
	background-position: center center;
}

.container {
	width: 79%;
	height: 84%;
	overflow-y: scroll;
	overflow-x: hidden;
	padding-bottom: 35rem;
}

div {
	color: white;
	font-style: bold;
	text-align: right;
	padding-right: 2.9rem;
}

.navbar-expand-sm .navbar-nav .nav-link {
	padding-right: 1.5rem;
	padding-left: .5rem;
	color: white;
	padding-top: 5rem;
	font-style: bold;
}

#navbarSupportedContent {
	color: white;
	font-style: bold;
	height: 151px;
	text-align: center;
	padding-left: 5rem;
}

tr {
	color: white;
	text-align: center;
	padding-left: 25rem;
}

.btn.btn-info {
	color: white;
	background-color: unset;
	border-color: unset;
}